# Iron Trainer helper app — fastlane automation.
#
# The Xcode project is generated by XcodeGen (no .xcodeproj is committed), so
# every lane regenerates it first. Common usage:
#   bundle exec fastlane tests     # generate + run unit tests
#   bundle exec fastlane build     # generate + build a dev .app/.ipa
#   bundle exec fastlane beta      # generate + sign + upload to TestFlight
default_platform(:ios)

WORKSPACE_DIR = File.expand_path("..", __dir__)   # the ios/ folder
SCHEME = "IronTrainer"
PROJECT = "IronTrainer.xcodeproj"

platform :ios do
  desc "Regenerate IronTrainer.xcodeproj from project.yml (XcodeGen)"
  lane :generate_project do
    Dir.chdir(WORKSPACE_DIR) do
      sh("command -v xcodegen >/dev/null 2>&1 || brew install xcodegen")
      sh("xcodegen generate")
    end
  end

  desc "Run unit tests on a simulator"
  lane :tests do
    generate_project
    run_tests(
      project: File.join(WORKSPACE_DIR, PROJECT),
      scheme: SCHEME,
      destination: "platform=iOS Simulator,name=iPhone 16,OS=18.0"
    )
  end

  desc "Build a development app (no signing required for the simulator)"
  lane :build do
    generate_project
    build_app(
      project: File.join(WORKSPACE_DIR, PROJECT),
      scheme: SCHEME,
      skip_archive: true,
      skip_codesigning: true,
      destination: "generic/platform=iOS Simulator"
    )
  end

  desc "Build a signed release and upload it to TestFlight"
  lane :beta do
    generate_project
    # App Store signing assets via match (set MATCH_GIT_URL); falls back to
    # automatic signing if match isn't configured.
    sync_code_signing(type: "appstore", readonly: true) if ENV["MATCH_GIT_URL"]
    increment_build_number(
      build_number: ENV["BUILD_NUMBER"] || Time.now.strftime("%Y%m%d%H%M"),
      xcodeproj: File.join(WORKSPACE_DIR, PROJECT)
    )
    build_app(
      project: File.join(WORKSPACE_DIR, PROJECT),
      scheme: SCHEME,
      export_method: "app-store"
    )
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      api_key_path: ENV["APP_STORE_CONNECT_API_KEY_PATH"]
    )
  end
end
