# Iron Trainer helper app — fastlane automation.
#
# The Xcode project is generated by XcodeGen (no .xcodeproj is committed), so
# every lane regenerates it first. Common usage:
#   bundle exec fastlane tests     # generate + run unit tests
#   bundle exec fastlane build     # generate + build a dev .app/.ipa
#   bundle exec fastlane beta      # generate + sign + upload to TestFlight
default_platform(:ios)

WORKSPACE_DIR = File.expand_path("..", __dir__)   # the ios/ folder
SCHEME = "IronTrainer"
PROJECT = "IronTrainer.xcodeproj"

platform :ios do
  desc "Regenerate IronTrainer.xcodeproj from project.yml (XcodeGen)"
  lane :generate_project do
    Dir.chdir(WORKSPACE_DIR) do
      sh("command -v xcodegen >/dev/null 2>&1 || brew install xcodegen")
      sh("xcodegen generate")
    end
  end

  desc "Run unit tests on a simulator"
  lane :tests do
    generate_project
    run_tests(
      project: File.join(WORKSPACE_DIR, PROJECT),
      scheme: SCHEME,
      destination: "platform=iOS Simulator,name=iPhone 16,OS=18.0"
    )
  end

  desc "Build a development app (no signing required for the simulator)"
  lane :build do
    generate_project
    build_app(
      project: File.join(WORKSPACE_DIR, PROJECT),
      scheme: SCHEME,
      skip_archive: true,
      skip_codesigning: true,
      destination: "generic/platform=iOS Simulator"
    )
  end

  desc "Build a signed release and upload it to TestFlight"
  lane :beta do
    generate_project
    # Xcode's exportArchive copies the Symbols dir with the system rsync
    # (/usr/bin/rsync = openrsync, protocol 29) but spawns its server peer via
    # PATH. If Homebrew's rsync 3.4.x (protocol 32) is first, the client/server
    # mismatch fails with "Copy failed". Force ONLY rsync to the system binary via
    # a shim dir (prepending all of /usr/bin would shadow rbenv Ruby and break the
    # xcpretty pipe).
    if File.executable?("/usr/bin/rsync")
      shim = File.join(WORKSPACE_DIR, ".build", "rsync-shim")
      FileUtils.mkdir_p(shim)
      link = File.join(shim, "rsync")
      File.symlink("/usr/bin/rsync", link) unless File.symlink?(link)
      ENV["PATH"] = "#{shim}:#{ENV['PATH']}"
    end
    # App Store signing assets via match (set MATCH_GIT_URL); falls back to
    # Xcode automatic signing if match isn't configured. NOTE: an empty string is
    # truthy in Ruby, so check for a non-blank value, not just presence.
    use_match = !(ENV["MATCH_GIT_URL"] || "").strip.empty?
    sync_code_signing(type: "appstore", readonly: true) if use_match
    # The project is regenerated by XcodeGen each run, so set the build number as
    # a build setting at archive time instead of mutating the project with agvtool.
    # NOTE: an empty env var is truthy in Ruby — treat blank as unset, else an
    # empty CURRENT_PROJECT_VERSION blanks CFBundleVersion and export "Copy failed".
    env_build = (ENV["BUILD_NUMBER"] || "").strip
    build_number = env_build.empty? ? Time.now.strftime("%Y%m%d%H%M") : env_build
    xcargs = ["CURRENT_PROJECT_VERSION=#{build_number}"]
    xcargs << "-allowProvisioningUpdates" unless use_match
    build_app(
      project: File.join(WORKSPACE_DIR, PROJECT),
      scheme: SCHEME,
      export_method: "app-store",
      xcargs: xcargs.join(" ")
    )
    # Build the ASC API key from the JSON at APP_STORE_CONNECT_API_KEY_PATH.
    # We parse it ourselves and feed app_store_connect_api_key so BOTH a .p8 path
    # (key_filepath) and inline PEM (key) work — upload_to_testflight's own
    # api_key_path uses a stricter loader that requires the inline `key` field.
    api_key = nil
    raw_key_path = (ENV["APP_STORE_CONNECT_API_KEY_PATH"] || "").strip
    # The path may be relative; fastlane's cwd is unreliable, so probe known
    # anchors (cwd, ios/, ios/fastlane/) and use the first that exists.
    key_path =
      if raw_key_path.empty?
        ""
      else
        [File.expand_path(raw_key_path),
         File.expand_path(raw_key_path, WORKSPACE_DIR),
         File.expand_path(raw_key_path, File.join(WORKSPACE_DIR, "fastlane"))]
          .find { |p| File.exist?(p) } || File.expand_path(raw_key_path)
      end
    if !key_path.empty? && File.exist?(key_path)
      require "json"
      cfg = JSON.parse(File.read(key_path))
      p8 = cfg["key_filepath"]
      p8 = File.expand_path(p8) if p8 && !p8.empty?
      api_key = app_store_connect_api_key(
        key_id: cfg["key_id"],
        issuer_id: cfg["issuer_id"],
        key_filepath: p8,
        key_content: cfg["key"],
        in_house: cfg.fetch("in_house", false)
      )
    end
    # Stop upload_to_testflight from falling back to its strict api_key_path loader
    # (which requires inline `key`); we pass the resolved api_key object instead.
    ENV.delete("APP_STORE_CONNECT_API_KEY_PATH")
    UI.user_error!("Couldn't resolve an ASC API key from #{key_path.empty? ? '(APP_STORE_CONNECT_API_KEY_PATH unset)' : key_path}") if api_key.nil?
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
