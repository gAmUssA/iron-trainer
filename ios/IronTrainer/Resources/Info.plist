<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Only exempt encryption is used (HTTPS/ATS, OS Keychain) — declaring it
         here skips the per-build Export Compliance questionnaire in TestFlight. -->
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleName</key>
    <string>Iron Trainer</string>
    <key>CFBundleDisplayName</key>
    <string>Iron Trainer</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>
    <key>UILaunchScreen</key>
    <dict/>

    <!-- Required by App Store validation (90474). iPad needs all four for multitasking. -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <!-- Declaring CFBundleDocumentTypes (.itw) requires this (90737); we open in place. -->
    <key>LSSupportsOpeningDocumentsInPlace</key>
    <true/>

    <!-- Camera: scanning the pairing QR from the web app. -->
    <key>NSCameraUsageDescription</key>
    <string>Iron Trainer uses the camera to scan the pairing QR code from the web app.</string>

    <!-- Custom URL scheme so an irontrainer://pair?… link signs the app in. -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>io.gamov.irontrainer.pair</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>irontrainer</string>
            </array>
        </dict>
    </array>

    <!-- WorkoutKit / HealthKit usage strings (required for review). -->
    <key>NSHealthShareUsageDescription</key>
    <string>Iron Trainer reads your sleep, heart-rate variability, resting and workout heart rate, respiratory rate, wrist temperature, body mass and VO₂ max from Health to compute your daily readiness and build structured workouts.</string>
    <key>NSHealthUpdateUsageDescription</key>
    <string>Iron Trainer schedules workouts so they appear on your Apple Watch.</string>

    <!-- Declare ownership of the .itw document type so files open in this app. -->
    <key>UTExportedTypeDeclarations</key>
    <array>
        <dict>
            <key>UTTypeIdentifier</key>
            <string>io.gamov.irontrainer.itw</string>
            <key>UTTypeDescription</key>
            <string>Iron Trainer Workout</string>
            <key>UTTypeConformsTo</key>
            <array>
                <string>public.json</string>
            </array>
            <key>UTTypeTagSpecification</key>
            <dict>
                <key>public.filename-extension</key>
                <array>
                    <string>itw</string>
                </array>
                <key>public.mime-type</key>
                <array>
                    <string>application/json</string>
                </array>
            </dict>
        </dict>
    </array>
    <key>CFBundleDocumentTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeName</key>
            <string>Iron Trainer Workout</string>
            <key>LSHandlerRank</key>
            <string>Owner</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>io.gamov.irontrainer.itw</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
