# Copy to ios/.env (gitignored) for local signed builds, or set as CI secrets.
# Read by fastlane (Appfile / Fastfile).

# Apple account + teams
APPLE_ID=you@example.com
ITC_TEAM_ID=               # App Store Connect team id (numeric)
TEAM_ID=                   # Apple Developer portal team id (10 chars)

# App Store Connect API key (preferred over Apple ID password for CI uploads)
APP_STORE_CONNECT_API_KEY_PATH=

# Code signing via match (optional). Leave unset to use Xcode automatic signing.
MATCH_GIT_URL=

# Optional explicit build number for `beta` (defaults to a timestamp)
BUILD_NUMBER=
