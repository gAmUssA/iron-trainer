# ── Strava API (https://www.strava.com/settings/api) ──────────────────────────
# Create an application; set "Authorization Callback Domain" to: localhost
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:8000/api/strava/callback

# ── Claude API (https://console.anthropic.com/) ───────────────────────────────
ANTHROPIC_API_KEY=
# Model used for weekly re-planning (cheaper) and the initial full-season plan.
PLANNER_MODEL=claude-sonnet-4-6
SEASON_MODEL=claude-opus-4-8

# ── App ───────────────────────────────────────────────────────────────────────
# Where the local SQLite file and generated workout files live.
DATA_DIR=./data
# Database: leave empty for local SQLite (under DATA_DIR). For Postgres/Supabase,
# set a SQLAlchemy URL (use the pooled port 6543 + SSL on Supabase):
#   DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:6543/postgres?sslmode=require
DATABASE_URL=
# Race target (defaults baked in; override here if needed).
RACE_NAME=IRONMAN 70.3 New York
RACE_DATE=2026-09-26
# Comma-separated origins allowed to call the API (the Vite dev server).
CORS_ORIGINS=http://localhost:5173

# ── Multi-user auth ───────────────────────────────────────────────────────────
# Off by default → local single-user, no login. Turn on for a deployment.
AUTH_REQUIRED=false
# Required when AUTH_REQUIRED=true. Use a long random string.
SESSION_SECRET=dev-insecure-change-me
# Comma-separated Strava athlete ids allowed to log in (empty = allow anyone).
ALLOWED_STRAVA_IDS=
# Set true when serving over HTTPS so the session cookie is marked Secure.
COOKIE_SECURE=false
# Ignore Strava activities older than this many years (0 = keep everything).
HISTORY_YEARS=5
